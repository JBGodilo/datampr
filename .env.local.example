# Supabase (persists saved source credentials, validation rules, and HubSpot token)
# Run supabase/migrations/0001_data_source_credentials.sql in the SQL editor first.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public-facing copies of the same Supabase values, needed by @supabase/ssr in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HubSpot tokens are managed in-app via the HubSpot connection dialog and stored in
# Supabase. There is no longer an env-var fallback.
